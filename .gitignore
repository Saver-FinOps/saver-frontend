/.agents/

# gstack toolchain (per-user)
/skills-lock.json

# posthog wizard report (one-shot)
/posthog-setup-report.md

# scan reports (per-customer, contain account IDs — never commit)
/reports/
/preview.html
*.scan.html
*.scan.json

# lead tracking (contains emails, External IDs — never commit)
/data/leads/
